rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidSimulation(data) {
      return data.keys().hasAll(['userId', 'input', 'output', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.userId == request.auth.uid &&
             data.input is map &&
             data.output is map &&
             data.createdAt is number;
    }

    match /users/{userId}/simulations/{simulationId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow list: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && isValidId(userId) && isValidId(simulationId) &&
                    request.auth.uid == userId && 
                    isValidSimulation(incoming());
      
      // Updates and deletes are not explicitly required, this is historically append-only initially
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
